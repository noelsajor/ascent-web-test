---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getAllPosts, getPostBySlug, getRelatedPosts } from '../../lib/sanity';

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post) => ({
    params: { slug: post.slug.current },
    props: { post },
  }));
}

const { slug } = Astro.params;
const { post: propsPost } = Astro.props;
const post = propsPost || await getPostBySlug(slug);

if (!post) {
  return Astro.redirect('/404');
}

const relatedPosts = await getRelatedPosts(slug, post.categories?.[0]?.title).catch(() => []);

// Simple Helper to build Sanity image URLs
const projectId = import.meta.env.PUBLIC_SANITY_PROJECT_ID;
const dataset = import.meta.env.PUBLIC_SANITY_DATASET || 'production';

function urlFor(source) {
  if (!source || !source.asset || !source.asset._ref) return '';
  const ref = source.asset._ref;
  const [_file, id, dimensions, extension] = ref.split('-');
  return `https://cdn.sanity.io/images/${projectId}/${dataset}/${id}-${dimensions}.${extension}`;
}

const mainImageUrl = urlFor(post.mainImage);

// Very basic Portable Text to HTML converter
function portableTextToHtml(blocks) {
  if (!blocks) return '';
  return blocks.map(block => {
    if (block._type !== 'block' || !block.children) {
      if (block._type === 'image') {
        return `<img src="${urlFor(block)}" alt="" />`;
      }
      return '';
    }

    const { style = 'normal' } = block;
    const children = block.children.map(child => {
      let text = child.text;
      if (child.marks) {
        // Very basic mark handling (strong, em)
        if (child.marks.includes('strong')) text = `<strong>${text}</strong>`;
        if (child.marks.includes('em')) text = `<em>${text}</em>`;
      }
      return text;
    }).join('');

    switch (style) {
      case 'h1': return `<h1>${children}</h1>`;
      case 'h2': return `<h2>${children}</h2>`;
      case 'h3': return `<h3>${children}</h3>`;
      case 'h4': return `<h4>${children}</h4>`;
      case 'blockquote': return `<blockquote>${children}</blockquote>`;
      default: return `<p>${children}</p>`;
    }
  }).join('');
}

const bodyHtml = portableTextToHtml(post.body);
const date = post.publishedAt || post._createdAt;
const displayDate = date ? new Date(date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) : 'Recently';
---

<BaseLayout title={`${post.title} | Ascent Mgnt`} activePage="blog">
  <article class="py-24 md:py-32">
    <div class="container">
      {/* 1. Header Section */}
      <div class="max-w-4xl mx-auto text-center mb-16 md:mb-24 reveal-item">
        <div class="flex flex-wrap items-center justify-center gap-4 text-sm font-semibold tracking-wide text-muted mb-8 uppercase">
          <span class="text-accent">{post.categories?.[0]?.title || 'Insight'}</span>
          <span class="w-1 h-1 bg-muted/50 rounded-full"></span>
          <span>{displayDate}</span>
        </div>
        
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-normal leading-[1.1] mb-12 text-text">
          {post.title}
        </h1>
        
        {post.author && (
          <div class="flex items-center justify-center gap-4 text-muted/80">
            {post.author.image && (
              <img 
                src={urlFor(post.author.image)} 
                alt={post.author.name} 
                class="w-12 h-12 rounded-full object-cover border border-line shadow-sm" 
              />
            )}
            <span class="text-md font-medium tracking-wide">By {post.author.name}</span>
          </div>
        )}
      </div>

      {/* 2. Hero Image */}
      {mainImageUrl && (
        <div class="max-w-5xl mx-auto mb-16 md:mb-24 reveal-item relative">
          <div class="w-full aspect-video rounded-3xl overflow-hidden bg-surface-2 border border-line shadow-[0_16px_40px_rgba(0,0,0,0.6)]">
            <img 
              src={mainImageUrl} 
              alt={post.title} 
              class="w-full h-full object-cover"
            />
          </div>
          {/* Subtle decorative glow */}
          <div class="absolute inset-0 bg-accent/20 blur-[100px] -z-10 rounded-full opacity-30 transform scale-90 translate-y-8"></div>
        </div>
      )}

      {/* 3. Body Content */}
      <div class="post-content reveal-item" set:html={bodyHtml} />

      {relatedPosts.length > 0 && (
        <div class="related-posts reveal-item">
          <h2>Related Posts</h2>
          <div class="portfolio-grid">
            {relatedPosts.map((p) => (
              <BlogCard post={p} />
            ))}
          </div>
        </div>
      )}
    </div>
  </article>
</BaseLayout>

<style is:global>
  /* Base editorial styling */
  .post-content {
    max-width: 46rem; /* Ideal reading line length ~65-75 chars */
    margin: 0 auto;
    font-size: 1.15rem;
    line-height: 1.85;
    color: var(--text);
  }

  /* Typography / Headings */
  .post-content h1, 
  .post-content h2, 
  .post-content h3, 
  .post-content h4 {
    font-family: inherit; /* GFS Didot is set broadly in Tailwind, but let's enforce it */
    color: var(--text);
    font-weight: 400;
  }
  
  .post-content h2 {
    font-family: 'GFS Didot', serif !important;
    font-size: 2.25rem;
    line-height: 1.3;
    margin: 4rem 0 1.5rem;
  }

  .post-content h3 {
    font-family: 'GFS Didot', serif !important;
    font-size: 1.75rem;
    line-height: 1.4;
    margin: 3rem 0 1.25rem;
  }

  /* Spacing */
  .post-content p {
    margin-bottom: 2rem;
    color: rgba(255, 255, 255, 0.85); /* Slightly muted for better contrast/reading */
  }

  /* Rich elements */
  .post-content blockquote {
    border-left: 4px solid var(--accent);
    padding: 2rem 2.5rem;
    margin: 3rem 0;
    background: var(--surface);
    border-radius: 0 1rem 1rem 0;
    font-style: italic;
    font-size: 1.35rem;
    line-height: 1.6;
    color: var(--text);
  }

  .post-content strong {
    color: var(--text);
    font-weight: 600;
  }

  .post-content a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid rgba(233, 208, 144, 0.3);
    transition: all 0.2s ease;
  }
  
  .post-content a:hover {
    border-bottom-color: var(--accent);
    opacity: 0.9;
  }

  .post-content img {
    border-radius: var(--radius-lg);
    margin: 3rem 0;
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    border: 1px solid var(--line);
  }
  
  /* Related Posts Footer */
  .related-posts {
    margin-top: 8rem;
    padding-top: 5rem;
    border-top: 1px solid var(--line);
  }
  
  .related-posts h2 {
    font-family: 'GFS Didot', serif !important;
    margin-bottom: 3rem;
    text-align: center;
    font-size: 2.5rem;
    font-weight: 400;
  }
</style>
