---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Portfolio from '../components/Portfolio.astro';
import Babysitter from '../components/Babysitter.astro';
import Packages from '../components/Packages.astro';
import TikTok from '../components/TikTok.astro';
import HowItWorks from '../components/HowItWorks.astro';
import BlogTeaser from '../components/BlogTeaser.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import FinalCTA from '../components/FinalCTA.astro';

const title = "We Build Your Brand | Done-For-You Creative & Social Commerce";
const description = "Overwhelmed? Ascent is the agency building brands from idea to execution. We handle content creation & social media so you don't have to.";
---

<BaseLayout title={title} description={description} activePage="home">
  <Hero />
  <Portfolio />
  <Babysitter />
  <Packages />
  <TikTok />
  <HowItWorks />
  <BlogTeaser />
  <Testimonials />
  <FAQ />
  <FinalCTA />
</BaseLayout>
