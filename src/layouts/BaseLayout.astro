---
import SEO from "../components/SEO.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import JSONLD from "../components/JSONLD.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  activePage?: string;
  type?: string;
}

const { title, description, activePage, type } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <SEO title={title} description={description} />
    <JSONLD title={title} description={description} type={type} />
    <meta
      name="google-site-verification"
      content="7r_mh6wY9bW0Bd_xCtQJXtWR_9TlEmcdv6qvR_t9_sc"
    />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-NRF9V8QJYR"
    ></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-NRF9V8QJYR");
    </script>
  </head>
  <body>
    <Header activePage={activePage} />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <script src="../scripts/reveal.js"></script>
  </body>
</html>
