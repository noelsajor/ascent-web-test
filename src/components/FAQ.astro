---
const faqs = [
  {
    question: "Is this for tiny brands or bigger brands?",
    answer: "We work with small businesses in early to growth stage. If you're overwhelmed by managing brand, content, and execution yourself, you're a fit. If you're a huge corporation with an internal team, probably not."
  },
  {
    question: "Do you actually do the content creation and posting?",
    answer: "Yes. We create the content, schedule it, post it, and manage your social accounts. You approve direction upfront, but we handle daily execution so you don't have to think about it."
  },
  {
    question: "Can you work with my existing brand or do I need a full rebuild?",
    answer: "Both. The Enhancement Package is for existing brands that need elevation and consistent execution. The Creation Package is for new brands or complete rebuilds. We assess during the call."
  },
  {
    question: "Do you build Shopify sites too?",
    answer: "Yes. Shopify design and build is included in the Creation Package. We also optimize existing Shopify sites in the Enhancement Package if needed."
  },
  {
    question: "How fast can we start?",
    answer: "After the call and estimate approval, typically 1–2 weeks. We protect quality by limiting monthly client intake, so there may be a short wait depending on capacity."
  },
  {
    question: "What if I want to manage some parts myself?",
    answer: "Then we're probably not a fit. Our model is built for founders who want one partner to handle execution end-to-end. If you want to DIY parts of it, you'll be better served elsewhere."
  },
  {
    question: "Do you guarantee specific results or metrics?",
    answer: "No. We guarantee quality execution, consistency, and strategic clarity. We can't control what your audience does, but we can control showing up with premium content daily."
  }
];
---

<section class="py-24 md:py-32" id="faq">
  <div class="container">
    <div class="text-center mb-16 md:mb-24 reveal-item">
      <div class="inline-flex mb-4">
        <span class="px-4 py-1.5 bg-accent/10 border border-accent/20 rounded-full text-xs font-bold text-accent tracking-widest uppercase">
          FAQ
        </span>
      </div>
      <h2 class="text-4xl md:text-5xl font-heading font-bold mb-4 tracking-tight">Common Questions</h2>
      <p class="text-lg text-muted max-w-xl mx-auto leading-relaxed">Everything you need to know about our approach and services.</p>
    </div>

    <div class="max-w-3xl mx-auto space-y-4">
      {faqs.map((faq) => (
        <details class="group bg-surface border border-line rounded-3xl overflow-hidden transition-all duration-300 hover:border-accent/40 reveal-item">
          <summary class="flex justify-between items-center p-6 md:p-8 cursor-pointer select-none focus:outline-none focus:ring-2 focus:ring-inset focus:ring-accent/20">
            <span class="text-lg font-bold text-text group-open:text-accent transition-colors">
              {faq.question}
            </span>
            <div class="w-8 h-8 flex items-center justify-center rounded-full border border-line text-accent transition-transform duration-300 group-open:rotate-45">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
              </svg>
            </div>
          </summary>
          <div class="px-6 md:px-8 pb-8 animate-in fade-in slide-in-from-top-2 duration-300">
            <div class="pt-4 border-t border-line">
              <p class="text-muted leading-relaxed italic">
                {faq.answer}
              </p>
            </div>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
