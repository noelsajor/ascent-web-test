---
const { activePage = 'home' } = Astro.props;

const navItems = [
  { href: '/', label: 'Home', key: 'home' },
  { href: '/work', label: 'Work', key: 'work' },
  { href: '/packages', label: 'Packages', key: 'packages' },
  { href: '/product', label: 'Product', key: 'product' },
  { href: '/about', label: 'About', key: 'about' },
  { href: '/blog', label: 'Blog', key: 'blog' },
  { href: '/contact', label: 'Contact', key: 'contact' },
];
---

<header id="main-header" class="sticky top-0 z-50 transition-all duration-300 bg-bg-0/80 backdrop-blur-md border-b border-line">
  <div class="container py-4 flex justify-between items-center">
    <a href="/" class="flex items-center gap-3 transition-opacity hover:opacity-80" aria-label="Ascent Mgnt">
      <img src="/assets/ascent_logo.svg" alt="Ascent Management logo" class="h-10 w-auto" />
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:block">
      <ul class="flex items-center gap-8">
        {navItems.map((item) => (
          <li>
            <a 
              href={item.href} 
              class={`text-sm font-medium transition-colors hover:text-accent focus-visible:text-accent focus-visible:outline-none ${activePage === item.key ? 'text-accent' : 'text-muted'}`}
            >
              {item.label}
            </a>
          </li>
        ))}
        <li>
          <a href="https://calendly.com/noelsajor/new-meeting?hide_gdpr_banner=1" class="btn-primary py-2 px-5 text-sm calendly-trigger" role="button" target="_blank" rel="noopener noreferrer">
            Book a Call
          </a>
        </li>
      </ul>
    </nav>

    <!-- Burger Menu Button -->
    <button
      id="burger-btn"
      class="group md:hidden flex flex-col justify-center items-center gap-1.5 w-10 h-10 bg-transparent border-none cursor-pointer z-50 relative"
      aria-label="Toggle mobile menu"
      aria-expanded="false"
    >
      <span class="w-6 h-0.5 bg-accent transition-all duration-300 group-[.active]:rotate-45 group-[.active]:translate-y-2"></span>
      <span class="w-6 h-0.5 bg-accent transition-all duration-300 group-[.active]:opacity-0"></span>
      <span class="w-6 h-0.5 bg-accent transition-all duration-300 group-[.active]:-rotate-45 group-[.active]:-translate-y-2"></span>
    </button>
  </div>
</header>

<!-- Mobile Menu Overlay - Outside Header Stacking Context -->
<div 
  id="mobile-overlay" 
  class="fixed inset-0 bg-bg-0 z-40 transition-all duration-500 opacity-0 pointer-events-none translate-x-full"
  aria-hidden="true"
>
  <div class="container h-full flex flex-col pt-32 pb-12">
    <nav class="flex-1">
      <ul class="flex flex-col gap-6">
        {navItems.map((item) => (
          <li>
            <a 
              href={item.href} 
              class={`text-4xl font-heading font-bold transition-colors hover:text-accent ${activePage === item.key ? 'text-accent' : 'text-text'}`}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <div class="mt-auto space-y-8">
      <a href="https://calendly.com/noelsajor/new-meeting?hide_gdpr_banner=1" class="btn-primary w-full py-5 text-xl calendly-trigger" role="button" target="_blank" rel="noopener noreferrer">
        Book a Call
      </a>
      <p class="text-center text-xs text-muted tracking-widest uppercase">
        &copy; {new Date().getFullYear()} Ascent Management
      </p>
    </div>
  </div>
</div>

<script>
  const header = document.getElementById('main-header');
  const burgerBtn = document.getElementById('burger-btn');
  const mobileOverlay = document.getElementById('mobile-overlay');
  
  // Header scroll logic
  window.addEventListener('scroll', () => {
    if (window.pageYOffset >= 12) {
      header?.classList.add('shadow-[0_4px_24px_rgba(0,0,0,0.4)]', 'bg-bg-0/95');
    } else {
      header?.classList.remove('shadow-[0_4px_24px_rgba(0,0,0,0.4)]', 'bg-bg-0/95');
    }
  }, { passive: true });

  // Mobile menu toggle logic
  function toggleMenu() {
    const isOpen = burgerBtn?.getAttribute('aria-expanded') === 'true';
    const newState = !isOpen;
    
    burgerBtn?.setAttribute('aria-expanded', newState.toString());
    burgerBtn?.classList.toggle('active', newState);
    
    if (mobileOverlay) {
      if (newState) {
        mobileOverlay.classList.remove('opacity-0', 'pointer-events-none', 'translate-x-full');
        mobileOverlay.classList.add('opacity-100', 'pointer-events-auto', 'translate-x-0');
        document.body.style.overflow = 'hidden';
      } else {
        mobileOverlay.classList.add('opacity-0', 'pointer-events-none', 'translate-x-full');
        mobileOverlay.classList.remove('opacity-100', 'pointer-events-auto', 'translate-x-0');
        document.body.style.overflow = '';
      }
    }
  }

  burgerBtn?.addEventListener('click', toggleMenu);
  
  // Close menu when clicking links
  mobileOverlay?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      if (burgerBtn?.classList.contains('active')) {
        toggleMenu();
      }
    });
  });

  // ESC key to close mobile menu
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && burgerBtn?.classList.contains('active')) {
      toggleMenu();
    }
  });

  // Calendly logic
  const triggers = document.querySelectorAll('.calendly-trigger');
  triggers.forEach(trigger => {
    trigger.addEventListener('click', (e) => {
      e.preventDefault();
      // @ts-ignore
      if (window.Calendly) {
        // @ts-ignore
        window.Calendly.initPopupWidget({ url: (e.currentTarget as HTMLAnchorElement).href });
      }
    });
  });
</script>

<script is:inline src="https://assets.calendly.com/assets/external/widget.js"></script>
