<section class="py-24 md:py-32" id="process">
  <div class="container">
    <div class="text-center mb-16 md:mb-24 reveal-item">
      <div class="inline-flex mb-4">
        <span class="px-4 py-1.5 bg-accent/10 border border-accent/20 rounded-full text-xs font-bold text-accent tracking-widest uppercase">
          Simple Process
        </span>
      </div>
      <h2 class="text-4xl md:text-5xl font-heading font-bold mb-4 tracking-tight">How It Works</h2>
      <p class="text-lg text-muted max-w-md mx-auto">Three steps. No friction.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="bg-surface border border-line rounded-3xl p-8 md:p-10 relative overflow-hidden transition-all duration-300 hover:border-accent/40 hover:shadow-xl hover:shadow-accent/5 reveal-item">
        <div class="text-5xl font-extrabold text-line mb-6 leading-none font-heading select-none">01</div>
        <h3 class="text-xl font-heading font-semibold text-text mb-3">Fill Out Short Form</h3>
        <p class="text-muted text-sm leading-relaxed">Tell us what you sell, your biggest challenge, and where you are. Takes 2 minutes.</p>
      </div>
      <div class="bg-surface border border-line rounded-3xl p-8 md:p-10 relative overflow-hidden transition-all duration-300 hover:border-accent/40 hover:shadow-xl hover:shadow-accent/5 reveal-item">
        <div class="text-5xl font-extrabold text-line mb-6 leading-none font-heading select-none">02</div>
        <h3 class="text-xl font-heading font-semibold text-text mb-3">Book a Call</h3>
        <p class="text-muted text-sm leading-relaxed">After submitting, you'll book a Calendly call directly. We review your needs and discuss fit.</p>
      </div>
      <div class="bg-surface border border-line rounded-3xl p-8 md:p-10 relative overflow-hidden transition-all duration-300 hover:border-accent/40 hover:shadow-xl hover:shadow-accent/5 reveal-item">
        <div class="text-5xl font-extrabold text-line mb-6 leading-none font-heading select-none">03</div>
        <h3 class="text-xl font-heading font-semibold text-text mb-3">We Send Estimate & Start</h3>
        <p class="text-muted text-sm leading-relaxed">After the call, we send a pricing estimate. Once approved, we start executing.</p>
      </div>
    </div>
  </div>
</section>
