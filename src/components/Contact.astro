---
const CALENDLY_URL = 'https://calendly.com/noelsajor/new-meeting?hide_gdpr_banner=1';
---

<section class="py-24 md:py-32" id="contact">
  <div class="container">
    <div class="text-center mb-16 md:mb-24 reveal-item">
      <h2 class="text-4xl md:text-5xl font-heading font-bold mb-6 tracking-tight">Book a Call</h2>
      <p class="text-lg text-muted max-w-xl mx-auto leading-relaxed">
        Fill out the form below and book your call directly. We'll review
        and send an estimate after.
      </p>
    </div>

    <div class="max-w-2xl mx-auto space-y-12">
      <form id="contact-form" class="bg-surface border border-line rounded-3xl p-8 md:p-12 reveal-item">
        <!-- Anti-Spam Honeypot -->
        <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" />
        
        <div class="space-y-6">
          <div>
            <label for="name" class="block text-sm font-bold text-text mb-2 px-1 uppercase tracking-widest">Your Name</label>
            <input
              type="text"
              id="name"
              name="name"
              placeholder="Full name"
              required
              class="w-full px-5 py-3 bg-bg-1/50 border border-line text-text rounded-xl text-sm transition-all focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent"
            />
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
            <div>
              <label for="brand" class="block text-sm font-bold text-text mb-2 px-1 uppercase tracking-widest">Brand / Website</label>
              <input
                type="text"
                id="brand"
                name="brand"
                placeholder="yourbrand.com"
                class="w-full px-5 py-3 bg-bg-1/50 border border-line text-text rounded-xl text-sm transition-all focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent"
              />
            </div>
            <div>
              <label for="product" class="block text-sm font-bold text-text mb-2 px-1 uppercase tracking-widest">What do you sell?</label>
              <input
                type="text"
                id="product"
                name="product"
                placeholder="e.g. Skincare"
                class="w-full px-5 py-3 bg-bg-1/50 border border-line text-text rounded-xl text-sm transition-all focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent"
              />
            </div>
          </div>

          <div>
            <label for="challenge" class="block text-sm font-bold text-text mb-2 px-1 uppercase tracking-widest">Biggest challenge right now</label>
            <textarea
              id="challenge"
              name="challenge"
              placeholder="What's overwhelming you?"
              class="w-full px-5 py-3 bg-bg-1/50 border border-line text-text rounded-xl text-sm transition-all focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent resize-none min-h-[120px]"
            ></textarea>
          </div>

          <div>
            <label for="email" class="block text-sm font-bold text-text mb-2 px-1 uppercase tracking-widest">Email Address</label>
            <input
              type="email"
              id="email"
              name="email"
              placeholder="you@email.com"
              required
              class="w-full px-5 py-3 bg-bg-1/50 border border-line text-text rounded-xl text-sm transition-all focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent"
            />
          </div>

          <button type="submit" class="btn-primary w-full py-4 text-lg">
            Submit & Book Call
          </button>
        </div>
      </form>

      <!-- Calendly Inline Embed -->
      <div class="bg-bg-1/30 border-2 border-dashed border-line rounded-3xl p-4 md:p-8 reveal-item">
        <div
          class="calendly-inline-widget rounded-2xl overflow-hidden"
          data-url={CALENDLY_URL}
          style="min-width: 320px; width: 100%; height: 700px;"
        ></div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());
      
      // Honeypot check
      if (data._gotcha) {
        return; // Silent fail for bots
      }

      alert('Thank you! Form submitted successfully.');
      // Actual submission logic would go here
    });
  }
</script>

<script is:inline src="https://assets.calendly.com/assets/external/widget.js"></script>
