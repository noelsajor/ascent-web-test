---
import BlogCard from './BlogCard.astro';
import { getLatestPosts } from '../lib/sanity';

const posts = await getLatestPosts(3).catch(() => []);
---

{posts.length > 0 && (
  <section class="py-24 md:py-32" id="blog">
    <div class="container">
      <div class="text-center mb-16 md:mb-24 reveal-item">
        <h2 class="text-4xl md:text-5xl font-heading font-bold mb-4 tracking-tight">Latest from the Blog</h2>
        <p class="text-lg text-muted max-w-xl mx-auto leading-relaxed">Insights on brand creation, content systems, and commerce execution.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => (
          <BlogCard post={post} />
        ))}
      </div>
      
      <div class="mt-16 md:mt-24 text-center reveal-item">
        <a href="/blog" class="inline-block px-8 py-3.5 bg-accent text-bg-0 no-underline rounded-full font-semibold transition-all duration-250 ease-[cubic-bezier(0.2,0.8,0.2,1)] border-none cursor-pointer text-[0.95rem] shadow-[0_2px_8px_rgba(233,208,144,0.15)] relative overflow-hidden min-h-[44px] text-center hover:bg-accent-2 hover:-translate-y-px hover:shadow-[0_8px_24px_rgba(233,208,144,0.3)] active:translate-y-0 focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-4 before:content-[''] before:absolute before:top-0 before:left-[-100%] before:w-full before:h-full before:bg-gradient-to-r before:from-transparent before:via-white/30 before:to-transparent before:transition-[left] before:duration-400 before:ease-out hover:before:left-[100%]">View All Posts</a>
      </div>
    </div>
  </section>
)}
